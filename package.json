{
  "name": "@rtc-less/rtc-components",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lit Web Components for WebRTC video conferencing UI",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "wtr",
    "test:watch": "wtr --watch"
  },
  "keywords": [
    "web-components",
    "lit",
    "webrtc",
    "video-conferencing",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@types/node": "^22.10.5",
    "@web/dev-server-esbuild": "^1.0.2",
    "@web/test-runner": "^0.18.0",
    "@web/test-runner-playwright": "^0.11.0",
    "typescript": "^5.9.3"
  }
}
